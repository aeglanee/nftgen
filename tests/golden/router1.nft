#!/usr/sbin/nft -f
# generated by nftgen from router1.yaml — do not edit

table inet raw {
    set bogon_ipv4 {
        type ipv4_addr
        flags interval
        elements = { 192.0.0.0/24, 192.0.2.0/24, 198.51.100.0/24, 203.0.113.0/24, 240.0.0.0/4 }
    }

    chain prerouting {
        type filter hook prerouting priority -300; policy accept;
        ip saddr @bogon_ipv4 counter drop
        ip daddr @bogon_ipv4 counter drop
        tcp flags & (fin|syn|rst|psh|ack|urg) == 0x0 counter drop
        tcp flags & (fin|syn) == (fin|syn) counter drop
        tcp flags & (fin|rst) == (fin|rst) counter drop
        tcp flags & (fin|ack) == fin counter drop
    }
}

table inet filter {
    set mgmt {
        type ipv4_addr
        flags interval
        elements = { 192.168.9.0/24 }
    }

    set webhosts {
        type ipv4_addr
        flags interval
        elements = { 192.0.2.10, 192.0.2.11 }
    }

    set web {
        type inet_service
        elements = { 80, 443 }
    }

    set ssh {
        type inet_service
        elements = { 22 }
    }

    set wan {
        type ifname
        elements = { "wan0", "wwan0" }
    }

    set lan_if {
        type ifname
        elements = { "lan0" }
    }

    set bogon_ipv4 {
        type ipv4_addr
        flags interval
        elements = { 192.0.0.0/24, 192.0.2.0/24, 198.51.100.0/24, 203.0.113.0/24, 240.0.0.0/4 }
    }

    set no_forward_ipv4 {
        type ipv4_addr
        flags interval
        elements = { 0.0.0.0/8, 127.0.0.0/8, 169.254.0.0/16, 224.0.0.0/4, 255.255.255.255/32 }
    }

    chain input {
        type filter hook input priority 0; policy drop;
        ct state established,related accept
        meta l4proto icmp accept
        meta l4proto icmpv6 accept
        ip saddr @mgmt tcp dport @ssh counter accept
        ip saddr @webhosts tcp dport @web counter accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
        ct state established,related accept
        ip daddr @no_forward_ipv4 counter drop
        tcp flags syn tcp option maxseg size set rt mtu
        iifname @lan_if oifname @wan ip saddr 192.168.10.0/24 tcp dport @web counter accept
    }
}

table inet nat {
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        oifname { "wan0", "wwan0" } ip saddr 192.168.10.0/24 masquerade
    }
}
