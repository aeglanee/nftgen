        ip saddr 192.168.1.0/24 ip daddr 10.0.1.0/24 tcp dport 5432 accept
        update @log_meter { ip saddr timeout 1m limit rate 4/minute } log prefix "fwd-users-services-drop " level info
        counter name policy_drops drop
    }

    chain fwd_users_dmz {
        ip saddr 192.168.1.0/24 ip daddr 10.0.11.0/24 tcp dport { 80, 443 } accept
        update @log_meter { ip saddr timeout 1m limit rate 4/minute } log prefix "fwd-users-dmz-drop " level info
        counter name policy_drops drop
