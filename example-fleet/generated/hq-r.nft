            198.51.100.0/24,
            203.0.113.0/24,
            224.0.0.0/4,
            240.0.0.0/4
        }
    }

    set bogons_v6 {
        type ipv6_addr
        flags interval
        elements = {
            ::/128,
            ::1/128,
            ::ffff:0:0/96,
            100::/64,
            2001:db8::/32,
            3fff::/20,
            fc00::/7,
            fe80::/10,
            ff00::/8
        }
    }

    set blocklist {
        type ipv4_addr
        flags interval, timeout
    }

    chain input {
        type filter hook input priority 0; policy drop;
        ct state established,related accept
        ct state invalid counter name ct_invalid drop
        iifname "lo" accept
        icmp type echo-request limit rate 5/second accept
        icmp type { echo-reply, destination-unreachable, time-exceeded, parameter-problem } accept
        icmpv6 type echo-request limit rate 5/second accept
        icmpv6 type { echo-reply, destination-unreachable, packet-too-big, time-exceeded, parameter-problem } accept
        icmpv6 type { nd-router-solicit, nd-router-advert, nd-neighbor-solicit, nd-neighbor-advert, nd-redirect } ip6 hoplimit 255 accept
        iifname "lan_nwm" ip saddr 10.90.1.0/24 tcp dport 22 accept
        iifname "lan_nwm" ip saddr 10.90.1.0/24 udp dport 161 accept
        update @log_meter { ip saddr timeout 1m limit rate 4/minute } log prefix "input-drop " level info
        counter name policy_drops drop
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
        ct state established,related flow add @ft
        ct state established,related accept
        ct state invalid counter name ct_invalid drop
        iifname { "wan0", "wan1" } ip saddr @bogons_v4 counter name bogon_drops drop
