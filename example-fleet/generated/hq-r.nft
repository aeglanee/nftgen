    }

    counter ct_invalid {
    }

    counter bogon_drops {
    }

    counter bad_tcp {
    }

    counter blocklist_drops {
    }

    counter policy_drops {
    }

    set bogons_v4 {
        type ipv4_addr
        flags interval
