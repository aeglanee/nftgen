---
extends: default

ignore: |
  .venv/

rules:
  line-length:
    max: 160
    allow-non-breakable-words: true
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  braces:
    # nftgen YAML is block-style by convention (CLAUDE.md) — no flow mappings
    forbid: true
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
