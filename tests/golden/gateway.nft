#!/usr/sbin/nft -f
# generated by nftgen from gateway.yaml — do not edit

table inet filter {
    flowtable ft {
        hook ingress priority 0
        devices = { "wan0", "wwan0", "lan0" }
    }

    counter bad_tcp {
    }

    counter web_hits {
    }

    counter ssh_excess {
    }

    set mgmt {
        type ipv4_addr
        flags interval
        elements = { 192.168.9.0/24 }
    }

    set webhosts {
        type ipv4_addr
        flags interval
        elements = { 192.0.2.10, 192.0.2.11 }
    }

    set web {
        type inet_service
        elements = { 80, 443 }
    }

    set ssh {
        type inet_service
        elements = { 22 }
    }

    set wan {
        type ifname
        elements = { "wan0", "wwan0" }
    }

    set lan_if {
        type ifname
        elements = { "lan0" }
    }

    set blocklist {
        type ipv4_addr
        flags interval, timeout
    }

    chain input {
        type filter hook input priority 0; policy drop;
        ct state established,related flow add @ft accept
        ip saddr @blocklist counter drop
        iifname vmap { "wan0" : jump input_wan, "lan0" : jump input_lan }
    }

    chain input_wan {
        tcp flags & (fin|syn|rst|psh|ack|urg) == 0x0 counter name bad_tcp drop
        tcp flags & (fin|syn) == (fin|syn) counter name bad_tcp drop
        tcp flags & (fin|ack) == fin counter name bad_tcp drop
        ct state new tcp dport @ssh limit rate 4/minute accept
        tcp dport @ssh log prefix "ssh-excess " level info counter name ssh_excess drop
        tcp dport @web counter name web_hits accept
    }

    chain input_lan {
        meta l4proto icmp accept
        ip saddr @mgmt tcp dport @ssh accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
        ct state established,related accept
        meta l4proto tcp tcp flags syn tcp option maxseg size set rt mtu
        iifname @lan_if oifname @wan meta mark set 0x1
        iifname @lan_if oifname @wan ip saddr 192.168.10.0/24 accept
        ip saddr @webhosts quota over 10 gbytes counter drop
        udp dport 5060 ip dscp set ef
    }
}

table inet nat {
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        oifname { "wan0", "wwan0" } ip saddr 192.168.10.0/24 masquerade
    }
}
