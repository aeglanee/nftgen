            "lan_users" . "lan_svc" : jump fwd_users_services,
            "lan_users" . "lan_dmz" : jump fwd_users_dmz,
            "lan_users" . "wan0" : jump fwd_users_inet,
            "lan_users" . "wan1" : jump fwd_users_inet,
            "lan_users" . "transit0" : jump fwd_users_transit,
            "lan_svc" . "wan0" : jump fwd_services_inet,
            "lan_svc" . "wan1" : jump fwd_services_inet,
            "lan_dmz" . "wan0" : jump fwd_dmz_inet,
            "lan_dmz" . "wan1" : jump fwd_dmz_inet,
            "lan_nwm" . "lan_svc" : jump fwd_nwm_services,
            "lan_nwm" . "transit0" : jump fwd_nwm_transit,
            "transit0" . "lan_svc" : jump fwd_transit_services,
            "transit0" . "lan_dmz" : jump fwd_transit_dmz,
            "wan0" . "lan_dmz" : jump fwd_wan_dmz,
            "wan1" . "lan_dmz" : jump fwd_wan_dmz
        }
        update @log_meter { ip saddr timeout 1m limit rate 4/minute } log prefix "fwd-nomatch-drop " level info
        counter name policy_drops drop
